AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_TEMPERATURE=0
AZURE_OPENAI_API_KEY=<your_azure_openai_api_key>
AZURE_OPENAI_ENDPOINT=https://ai-proxy.lab.epam.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── OPA-style Authorization ────────────────────────────────────────────────
# Format: role:api-key  (comma-separated, multiple keys per role allowed)
# DACL_API_KEYS=admin:sk-admin-secret,analyst:sk-analyst-key,reader:sk-reader-key
#
# Set DACL_OPEN_MODE=true to skip all auth (dev/demo only, NEVER in production)
DACL_OPEN_MODE=true

# ─── Action Dispatcher ──────────────────────────────────────────────────────
# Optional: POST a webhook on every rule decision (leave blank to disable)
# DACL_WEBHOOK_URL=https://hooks.example.com/dacl-decisions

DACL_JWT_SECRET=<your_jwt_secret>

# ─── LangSmith Tracing ────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="<your_langchain_api_key>"
LANGCHAIN_PROJECT="dacl-agent"
